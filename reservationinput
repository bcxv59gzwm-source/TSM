# ----- Change Order Variable -----
$ChangeOrder = "CHG123456"

# ----- CSV Location -----
$CsvPath = "C:\Users\Public\Desktop\reservations.csv"

# Import CSV
$Reservations = Import-Csv $CsvPath

foreach ($Reservation in $Reservations) {

    $ScopeID = $Reservation.ScopeID
    $MAC = $Reservation.MACAddress
    $IP = $Reservation.IPAddress
    $Queue = $Reservation.Queue

    # Build Description
    $Description = "$ChangeOrder - $Queue"

    try {
        Add-DhcpServerv4Reservation `
            -ScopeId $ScopeID `
            -IPAddress $IP `
            -ClientId $MAC `
            -Description $Description

        Write-Host "Added reservation $IP -> $MAC | $Description" -ForegroundColor Green
    }
    catch {
        Write-Host "Failed reservation $IP in scope $ScopeID" -ForegroundColor Red
    }
}