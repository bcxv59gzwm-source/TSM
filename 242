# DHCP Server Name (use localhost if running directly on server)
$DhcpServer = "localhost"

# CSV Path (Desktop)
$CsvPath = "$env:USERPROFILE\Desktop\242changes.csv"

# Backup file
$BackupPath = "$env:USERPROFILE\Desktop\DHCP_242_Backup_$(Get-Date -Format yyyyMMdd_HHmmss).csv"

# Import CSV
$Scopes = Import-Csv -Path $CsvPath

# Array to store backup data
$BackupData = @()

foreach ($Scope in $Scopes) {
    $ScopeId = $Scope.ScopeId
    $NewValue = $Scope.OptionValue

    Write-Host "Processing Scope: $ScopeId" -ForegroundColor Cyan

    # Validate scope exists
    $ExistingScope = Get-DhcpServerv4Scope -ComputerName $DhcpServer -ScopeId $ScopeId -ErrorAction SilentlyContinue

    if (-not $ExistingScope) {
        Write-Host "⚠️ Scope $ScopeId not found. Skipping..." -ForegroundColor Yellow
        continue
    }

    try {
        # Get current Option 242 value (if exists)
        $CurrentOption = Get-DhcpServerv4OptionValue -ComputerName $DhcpServer -ScopeId $ScopeId -OptionId 242 -ErrorAction SilentlyContinue

        $OldValue = if ($CurrentOption) {
            ($CurrentOption.Value -join ",")
        } else {
            "NOT SET"
        }

        # Save to backup
        $BackupData += [PSCustomObject]@{
            ScopeId   = $ScopeId
            OldValue  = $OldValue
        }

        # Set new Option 242 value
        Set-DhcpServerv4OptionValue `
            -ComputerName $DhcpServer `
            -ScopeId $ScopeId `
            -OptionId 242 `
            -Value $NewValue

        Write-Host "✅ Updated Option 242 for $ScopeId" -ForegroundColor Green
    }
    catch {
        Write-Host "❌ Error updating $ScopeId : $_" -ForegroundColor Red
    }
}

# Export backup
$BackupData | Export-Csv -Path $BackupPath -NoTypeInformation

Write-Host "`n📦 Backup saved to: $BackupPath" -ForegroundColor Magenta